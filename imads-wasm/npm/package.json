{
  "name": "imads-wasm",
  "version": "2.1.0",
  "description": "IMADS — Integrated Mesh Adaptive Direct Search (WASM)",
  "license": "(MIT OR Apache-2.0 OR LGPL-2.1-or-later)",
  "type": "module",
  "main": "./bundler/imads_wasm.js",
  "module": "./bundler/imads_wasm.js",
  "types": "./bundler/imads_wasm.d.ts",
  "exports": {
    ".": {
      "import": "./bundler/imads_wasm.js",
      "require": "./nodejs/imads_wasm.js",
      "types": "./bundler/imads_wasm.d.ts",
      "default": "./bundler/imads_wasm.js"
    },
    "./web": {
      "import": "./web/imads_wasm.js",
      "types": "./web/imads_wasm.d.ts"
    },
    "./bundler": {
      "import": "./bundler/imads_wasm.js",
      "types": "./bundler/imads_wasm.d.ts"
    },
    "./nodejs": {
      "require": "./nodejs/imads_wasm.js",
      "types": "./nodejs/imads_wasm.d.ts"
    }
  },
  "files": [
    "web/",
    "bundler/",
    "nodejs/"
  ],
  "sideEffects": false
}
